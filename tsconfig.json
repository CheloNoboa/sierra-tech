{
  /* =====================================================================
     🎯 CONFIGURACIÓN PRINCIPAL DE TYPESCRIPT — FastFood App
     =====================================================================
     ES:
       Configuración oficial para Next.js 15 + TypeScript 6+ (preparado para TS7).
       
       ✔ Eliminado "baseUrl" (DEPRECATED en TS6)
       ✔ Uso de "paths" moderno compatible con "moduleResolution: bundler"
       ✔ Alias "@/*" apuntando a "./src/*"
       ✔ Compatible con Turbopack
       ✔ Sin warnings ni deprecaciones

     EN:
       Official setup for Next.js 15 + TypeScript 6+ (TS7 ready).
       
       ✔ Removed deprecated "baseUrl"
       ✔ Modern "paths" usage with bundler resolution
       ✔ Alias "@/*" → "./src/*"
       ✔ Fully compatible with Turbopack
       ✔ No warnings or deprecations
  ===================================================================== */

  "compilerOptions": {
    /* --------------------------------------------------------
       🔄 Permitir archivos .js dentro del proyecto
       Allow JavaScript files if needed
    -------------------------------------------------------- */
    "allowJs": true,

    /* --------------------------------------------------------
       🎯 Target + Librerías base del runtime
       Target JS version + DOM support
    -------------------------------------------------------- */
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],

    /* --------------------------------------------------------
       📦 Sistema de módulos moderno (Next.js 15)
       Modern module system
    -------------------------------------------------------- */
    "module": "esnext",
    "moduleResolution": "bundler",

    /* --------------------------------------------------------
       🔎 Importaciones JSON y compatibilidad ES modules
    -------------------------------------------------------- */
    "resolveJsonModule": true,
    "esModuleInterop": true,

    /* --------------------------------------------------------
       🧪 Aislamiento de módulos (requerido por Next)
    -------------------------------------------------------- */
    "isolatedModules": true,

    /* --------------------------------------------------------
       🎨 Soporte JSX nativo
    -------------------------------------------------------- */
    "jsx": "preserve",

    /* --------------------------------------------------------
       ⚡ Compilación incremental
       ❌ Desactivado por bug en Windows (Next 15 + Turbopack)
    -------------------------------------------------------- */
    "incremental": false,

    /* --------------------------------------------------------
       🚫 No emitir JS (Next maneja el build)
    -------------------------------------------------------- */
    "noEmit": true,

    /* --------------------------------------------------------
       🛑 Ignorar errores en node_modules
    -------------------------------------------------------- */
    "skipLibCheck": true,

    /* --------------------------------------------------------
       🚨 Modo estricto
    -------------------------------------------------------- */
    "strict": true,

    /* --------------------------------------------------------
       📁 ALIAS DE IMPORTACIÓN (ESTÁNDAR MODERNO)
       ❌ Sin baseUrl (deprecated TS6)
       ✔ Rutas relativas con "./"
    -------------------------------------------------------- */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* --------------------------------------------------------
       🧩 Plugin oficial de Next.js
    -------------------------------------------------------- */
    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  /* =====================================================================
     📁 ARCHIVOS INCLUIDOS
     =====================================================================
     ES:
       ✔ Archivos reales del proyecto
       ✔ Tipos generados por Next (.next/types)
       ✔ Definiciones globales (*.d.ts)

     EN:
       ✔ Project files only
       ✔ Next.js generated types
       ✔ Custom type definitions
  ====================================================================== */
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/types/**/*.d.ts"
  ],

  /* =====================================================================
     🚫 EXCLUSIONES
     ===================================================================== */
  "exclude": [
    "node_modules"
  ]
}