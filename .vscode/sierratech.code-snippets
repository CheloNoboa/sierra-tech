			" * - Manejo de errores estándar",
			" * -----------------------------------------------------------",
			" */",
			"",
			"import { NextResponse } from \"next/server\";",
			"import { connectToDB } from \"@/lib/connectToDB\";",
			"",
			"export async function GET() {",
			"  try {",
