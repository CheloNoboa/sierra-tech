	"Mongoose Model Boilerplate": {
		"prefix": "nxmodel",
		"body": [
			"/**",
			" * ✅ src/models/${1:Model}.ts",
			" * ------------------------------------------------------------",
			" * Modelo Mongoose para ${2:descripción}.",
			" * - Compatible con Next.js (hot reload)",
			" * - Usa colección \"${3:CollectionName}\"",
			" * ------------------------------------------------------------",
			" */",
			"",
			"import { Schema, model, models, Document } from \"mongoose\";",
			"",
			"export interface I${1:Model} extends Document {",
			"  // TODO: definir campos",
			"  name: string;",
			"  createdAt?: Date;",
			"}",
			"",
			"const ${1:Model}Schema = new Schema<I${1:Model}>(",
			"  {",
			"    name: { type: String, required: true },",
			"    createdAt: { type: Date, default: Date.now },",
			"  },",
			"  {",
			"    collection: \"${3:CollectionName}\",",
			"  }",
			");",
			"",
			"const ${1:Model} = models.${1:Model} || model<I${1:Model}>(\"${1:Model}\", ${1:Model}Schema);",
			"export default ${1:Model};",
			"",
		],
		"description": "Plantilla estándar para modelos Mongoose.",
	},

