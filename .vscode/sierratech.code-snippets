	"Next.js Page with Suspense Wrapper": {
		"prefix": "nxpage",
		"body": [
			"\"use client\";",
			"",
			"import { Suspense } from \"react\";",
			"import ${1:InnerComponent} from \"./${2:inner}\";",
			"",
			"export default function ${3:Page}() {",
			"  return (",
			"    <Suspense",
			"      fallback={",
			"        <div className=\\\"flex min-h-screen items-center justify-center bg-background text-text-secondary\\\">",
			"          Cargando...",
			"        </div>",
			"      }",
			"    >",
			"      <${1:InnerComponent} />",
			"    </Suspense>",
			"  );",
			"}",
			"",
		],
		"description": "Página Next.js envuelta en Suspense con fallback alineado al design system.",
	},

